def segment(row):

    if row['R']==5 and row['F']>=4:
        return 'Champions'

    elif row['R']>=4 and row['F']>=3:
        return 'Loyal'

    elif row['R']>=3:
        return 'Potential'

    elif row['R']==1:
        return 'Lost'

    else:
        return 'At Risk'

rfm['Segment'] = rfm.apply(segment,axis=1)
